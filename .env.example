# このファイルをコピーして .env を作成し、必要に応じて値を変更してください。
# .env は Git 管理対象外です（秘密情報を書いても公開されません）。
# 例: cp .env.example .env

# データベースファイルの保存先（省略時は data/jobs.db）
JOBS_DB_PATH=data/jobs.db

# アプリで使用するタイムゾーン
APP_TIMEZONE=Asia/Tokyo

# =============================================================================
# 第2段階: AI案件分析機能の設定
# =============================================================================
# AI_PROVIDER は openai / anthropic / gemini / none のいずれかを指定してください。
# none を指定するか、対応するAPIキーを設定しない場合は、AIを使わずルールベース分析のみで動作します。
AI_PROVIDER=none

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=設定画面または環境変数から指定

ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=設定画面または環境変数から指定

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=設定画面または環境変数から指定

# =============================================================================
# 第3段階: 営業文自動生成機能の設定
# =============================================================================
# 営業文生成用モデルは案件分析用モデルとは別に指定できます（省略時は分析用モデルと同じ値を使用）。
APPLICATION_OPENAI_MODEL=設定画面または環境変数から指定
APPLICATION_ANTHROPIC_MODEL=設定画面または環境変数から指定
APPLICATION_GEMINI_MODEL=設定画面または環境変数から指定
